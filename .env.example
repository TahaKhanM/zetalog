# ZetaLog environment variables.
# Copy to .env.local (apps/web) and fill in. NEVER commit real values.

# ── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Settings → API. URL + anon key are client-safe (RLS enforced).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY. Used by API routes for validated game writes and PB revocation.
# Must never appear in a client bundle or in the extension.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for running migrations (Dashboard → Settings → Database).
SUPABASE_DB_URL=

# ── Email — Resend via Supabase Auth SMTP ───────────────────────────────────
# Supabase's built-in sender is rate-limited to a handful of emails/hour and
# MUST NOT be used. Configure Resend as custom SMTP in the Supabase dashboard
# (Auth → SMTP settings) and keep the key here for the uni-verification OTP
# sender (apps/web/lib/email — the one module allowed to send email).
RESEND_API_KEY=

# From address for auth + verification emails.
EMAIL_FROM="ZetaLog <verify@example.com>"
